{
  "name": "jaad-pos",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "postcss": "^8.5.12"
  },
  "scripts": {
    "build:shared": "npm run build --workspace=packages/shared",
    "dev:backend": "npm run build:shared && npm run dev --workspace=packages/backend",
    "dev:customer": "npm run dev --workspace=packages/customer-app",
    "build:backend": "npm run build --workspace=packages/backend",
    "build:customer": "npm run build --workspace=packages/customer-app",
    "test:backend": "npm run test --workspace=packages/backend",
    "test:e2e": "npm run test:e2e --workspace=packages/customer-app"
  }
}
