{
  "name": "@jaad-pos/pos-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "expo:start": "npx expo start --lan --clear --port 8082",
    "test": "jest"
  },
  "dependencies": {
    "@jaad-pos/shared": "*",
    "expo": "~54.0.33",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "socket.io-client": "^4.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@react-native-community/cli": "latest",
    "@react-native/metro-config": "0.81.5",
    "@types/react": "~19.1.10",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~54.0.10",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": "babel-jest"
    },
    "moduleNameMapper": {
      "^@jaad-pos/shared$": "<rootDir>/../shared/src/index.ts"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts?(x)",
      "**/?(*.)+(spec|test).ts?(x)"
    ]
  }
}
