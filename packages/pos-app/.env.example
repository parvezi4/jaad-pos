# Copy this file to .env and fill in your local values.
# EXPO_PUBLIC_* variables are inlined into the bundle by Expo at build/serve time.
# They are safe to share in .env.example but should NOT be committed in .env
# if they contain machine-specific or sensitive values.

# Your Windows machine's LAN IP address (run `ipconfig` to find it).
# Required for Expo Go / physical iPhone testing so the app can reach the backend.
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:4000
EXPO_PUBLIC_API_URL=http://REPLACE_WITH_YOUR_LAN_IP:4000
EXPO_PUBLIC_SOCKET_URL=http://REPLACE_WITH_YOUR_LAN_IP:4000

# The restaurant slug to look up on startup.
EXPO_PUBLIC_RESTAURANT_SLUG=jaad-cafe
